# STEP 1: Set API port.
PORT=4000

# STEP 2: Set JWT config.
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=12h

# STEP 3: Set frontend origin for CORS.
CORS_ORIGIN=http://localhost:5173

# STEP 4: Set database connection string.
DATABASE_URL=postgres://postgres:admin@localhost:5433/fleet_db

# STEP 5: Set Redis connection string.
REDIS_URL=redis://localhost:6379

# STEP 6: Set simulation interval (ms).
SIMULATION_INTERVAL_MS=2000
